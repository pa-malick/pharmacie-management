<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- MENU RACINE -->
    <menuitem id="menu_pharmacie_root"
              name="Pharmacie"
              sequence="50"/>

    <!-- CAISSE : nouvelle vente et historique -->
    <menuitem id="menu_pharmacie_caisse"
              name="Caisse"
              parent="menu_pharmacie_root"
              sequence="10"/>

    <menuitem id="menu_pharmacie_vente_new"
              name="Nouvelle vente"
              parent="menu_pharmacie_caisse"
              action="action_pharmacie_vente_new"
              sequence="10"/>

    <menuitem id="menu_pharmacie_vente_list"
              name="Historique des ventes"
              parent="menu_pharmacie_caisse"
              action="action_pharmacie_vente"
              sequence="20"/>

    <!-- ORDONNANCES : liste des ordonnances medicales -->
    <menuitem id="menu_pharmacie_ordonnances"
              name="Ordonnances"
              parent="menu_pharmacie_root"
              sequence="20"/>

    <menuitem id="menu_pharmacie_ordonnance_list"
              name="Liste des ordonnances"
              parent="menu_pharmacie_ordonnances"
              action="action_pharmacie_ordonnance"
              sequence="10"/>

    <!-- STOCK : medicaments, lots et alertes de peremption -->
    <menuitem id="menu_pharmacie_stock"
              name="Stock"
              parent="menu_pharmacie_root"
              sequence="30"/>

    <menuitem id="menu_pharmacie_medicament_list"
              name="Médicaments"
              parent="menu_pharmacie_stock"
              action="action_pharmacie_medicament"
              sequence="10"/>

    <menuitem id="menu_pharmacie_lot_list"
              name="Lots et stocks"
              parent="menu_pharmacie_stock"
              action="action_pharmacie_lot"
              sequence="20"/>

    <menuitem id="menu_pharmacie_lot_alertes"
              name="Alertes de péremption / rupture"
              parent="menu_pharmacie_stock"
              action="action_pharmacie_lot_alertes"
              sequence="30"/>

    <!-- FOURNISSEURS : liste et bons de commande (reappro) -->
    <menuitem id="menu_pharmacie_fournisseurs"
              name="Fournisseurs"
              parent="menu_pharmacie_root"
              sequence="40"/>

    <menuitem id="menu_pharmacie_fournisseur_list"
              name="Liste des fournisseurs"
              parent="menu_pharmacie_fournisseurs"
              action="action_pharmacie_fournisseur"
              sequence="10"/>

    <menuitem id="menu_pharmacie_reappro_list"
              name="Réapprovisionnements"
              parent="menu_pharmacie_fournisseurs"
              action="action_pharmacie_reappro"
              sequence="20"/>

    <!-- RAPPORTS : bilan de caisse (visible Pharmacien et Gestionnaire) -->
    <menuitem id="menu_pharmacie_rapports"
              name="Rapports"
              parent="menu_pharmacie_root"
              sequence="50"
              groups="group_pharmacie_pharmacien,group_pharmacie_gestionnaire"/>

    <menuitem id="menu_pharmacie_bilan_caisse"
              name="Bilan de caisse"
              parent="menu_pharmacie_rapports"
              action="action_wizard_bilan_caisse"
              sequence="10"/>

    <!-- CONFIGURATION : categories et parametres (Pharmacien / Gestionnaire) -->
    <menuitem id="menu_pharmacie_config"
              name="Configuration"
              parent="menu_pharmacie_root"
              sequence="90"
              groups="group_pharmacie_pharmacien,group_pharmacie_gestionnaire"/>

    <menuitem id="menu_pharmacie_categorie"
              name="Catégories de médicaments"
              parent="menu_pharmacie_config"
              action="action_pharmacie_categorie"
              sequence="10"/>

    <menuitem id="menu_pharmacie_medicament_alertes"
              name="Paramètres de la pharmacie"
              parent="menu_pharmacie_config"
              action="action_pharmacie_medicament_alertes"
              sequence="20"/>

</odoo>
