<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Héritage vue formulaire res.partner : ajout onglet Fournisseur pharma -->
    <record id="view_partner_pharmacie_inherit" model="ir.ui.view">
        <field name="name">res.partner.form.pharmacie</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Ajout d'un bouton stat "Commandes" dans la button_box du partenaire -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button name="action_view_reappros" type="object"
                        class="oe_stat_button" icon="fa-truck"
                        invisible="not is_fournisseur_pharma">
                    <field name="reappro_count" widget="statinfo" string="Commandes"/>
                </button>
            </xpath>

            <!-- Ajout de l'onglet Pharmacie dans le notebook du partenaire -->
            <xpath expr="//notebook" position="inside">
                <page string="Pharmacie" name="pharmacie">
                    <group>
                        <group string="Identification pharmaceutique">
                            <field name="is_fournisseur_pharma" widget="boolean_toggle"/>
                            <field name="numero_agrement"
                                   invisible="not is_fournisseur_pharma"/>
                            <field name="delai_livraison_moyen"
                                   invisible="not is_fournisseur_pharma"/>
                        </group>
                        <group string="Statistiques"
                               invisible="not is_fournisseur_pharma">
                            <field name="reappro_count" readonly="1"/>
                        </group>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <!-- Action Fournisseurs pharmaceutiques -->
    <record id="action_pharmacie_fournisseur" model="ir.actions.act_window">
        <field name="name">Fournisseurs pharmaceutiques</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_fournisseur_pharma', '=', True)]</field>
        <field name="context">{'default_is_fournisseur_pharma': True, 'default_supplier_rank': 1}</field>
    </record>

</odoo>
