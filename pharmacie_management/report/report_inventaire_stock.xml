<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_inventaire_stock_template">
    <t t-call="web.html_container">
      <t t-call="web.external_layout">
        <div class="page">

          <!-- En-tête -->
          <div class="row mb-4">
            <div class="col-8">
              <h2>INVENTAIRE DES STOCKS</h2>
              <p class="text-muted">
                Édité le : <t t-esc="context_timestamp(datetime.datetime.now()).strftime('%d/%m/%Y à %H:%M')"/>
              </p>
            </div>
            <div class="col-4 text-right">
              <div class="badge badge-danger p-2">
                <span>Rouge = péremption &lt; 30 jours</span>
              </div><br/>
              <div class="badge badge-warning p-2">
                <span>Orange = péremption &lt; 90 jours</span>
              </div><br/>
              <div class="badge badge-success p-2">
                <span>Vert = stock normal</span>
              </div>
            </div>
          </div>

          <!-- Tableau lots groupés par médicament -->
          <table class="table table-bordered table-sm">
            <thead class="table-dark">
              <tr>
                <th>N° Lot</th>
                <th>Médicament</th>
                <th>DCI</th>
                <th>Catégorie</th>
                <th class="text-center">Qté initiale</th>
                <th class="text-center">Qté restante</th>
                <th class="text-center">Date péremption</th>
                <th class="text-center">Jours restants</th>
                <th class="text-center">Statut</th>
              </tr>
            </thead>
            <tbody>
              <t t-foreach="docs" t-as="lot">
                <tr t-attf-class="#{lot.jours_avant_peremption &lt; 30 and lot.statut == 'valide' and 'table-danger' or lot.jours_avant_peremption &lt; 90 and lot.statut == 'valide' and 'table-warning' or lot.statut != 'valide' and 'table-secondary' or ''}">
                  <td><t t-esc="lot.numero_lot"/></td>
                  <td><t t-esc="lot.medicament_id.nom_commercial"/></td>
                  <td><t t-esc="lot.medicament_id.dci or '—'"/></td>
                  <td><t t-esc="lot.medicament_id.categorie_id.name"/></td>
                  <td class="text-center"><t t-esc="lot.quantite_initiale"/></td>
                  <td class="text-center"><strong><t t-esc="lot.quantite_restante"/></strong></td>
                  <td class="text-center">
                    <t t-esc="lot.date_peremption" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>
                  </td>
                  <td class="text-center">
                    <t t-if="lot.statut == 'valide'">
                      <t t-esc="lot.jours_avant_peremption"/> j
                    </t>
                    <t t-else="">—</t>
                  </td>
                  <td class="text-center">
                    <t t-if="lot.statut == 'valide'">
                      <span class="badge badge-success">Valide</span>
                    </t>
                    <t t-elif="lot.statut == 'expire'">
                      <span class="badge badge-danger">Expiré</span>
                    </t>
                    <t t-else="">
                      <span class="badge badge-secondary">Épuisé</span>
                    </t>
                  </td>
                </tr>
              </t>
            </tbody>
          </table>

          <div class="row mt-3">
            <div class="col-6">
              <strong>Total lots affichés :</strong> <t t-esc="len(docs)"/>
            </div>
            <div class="col-6 text-right">
              <p class="text-muted"><em>Signature du pharmacien responsable : ___________________</em></p>
            </div>
          </div>

        </div>
      </t>
    </t>
  </template>
</odoo>
