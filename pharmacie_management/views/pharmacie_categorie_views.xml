<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue formulaire Catégorie -->
    <record id="view_pharmacie_categorie_form" model="ir.ui.view">
        <field name="name">pharmacie.categorie.form</field>
        <field name="model">pharmacie.categorie</field>
        <field name="arch" type="xml">
            <form string="Catégorie de médicament">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name" placeholder="Nom de la catégorie..."/></h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="code"/>
                            <field name="parent_id"/>
                        </group>
                        <group string="Statistiques">
                            <field name="medicament_count" readonly="1"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"/>
                    </group>
                    <notebook>
                        <page string="Sous-catégories" name="children">
                            <field name="child_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="medicament_count"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue liste Catégorie -->
    <record id="view_pharmacie_categorie_tree" model="ir.ui.view">
        <field name="name">pharmacie.categorie.tree</field>
        <field name="model">pharmacie.categorie</field>
        <field name="arch" type="xml">
            <list string="Catégories">
                <field name="name"/>
                <field name="code"/>
                <field name="parent_id"/>
                <field name="medicament_count"/>
            </list>
        </field>
    </record>

    <!-- Vue recherche Catégorie -->
    <record id="view_pharmacie_categorie_search" model="ir.ui.view">
        <field name="name">pharmacie.categorie.search</field>
        <field name="model">pharmacie.categorie</field>
        <field name="arch" type="xml">
            <search>
                <field name="name" string="Catégorie"/>
                <field name="code"/>
                <field name="parent_id"/>
                <group expand="1" string="Regrouper par">
                    <filter name="by_parent" string="Catégorie parente"
                            context="{'group_by': 'parent_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action Catégorie -->
    <record id="action_pharmacie_categorie" model="ir.actions.act_window">
        <field name="path">pharmacie-categorie</field>
        <field name="name">Catégories de médicaments</field>
        <field name="res_model">pharmacie.categorie</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pharmacie_categorie_search"/>
    </record>

</odoo>
