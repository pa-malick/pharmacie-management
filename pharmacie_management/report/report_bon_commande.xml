<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <template id="report_bon_commande_template">
    <t t-foreach="docs" t-as="reappro">
      <t t-call="web.html_container">
        <t t-call="web.external_layout">
          <div class="page">

            <!-- En-tête du bon de commande -->
            <div class="row mb-4">
              <div class="col-6">
                <h2>BON DE COMMANDE FOURNISSEUR</h2>
                <h3><t t-esc="reappro.reference"/></h3>
                <p>Date commande :
                  <strong>
                    <t t-esc="reappro.date_commande" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>
                  </strong>
                </p>
                <t t-if="reappro.date_livraison_prevue">
                  <p>Livraison prévue :
                    <strong>
                      <t t-esc="reappro.date_livraison_prevue" t-options='{"widget": "date", "format": "dd/MM/yyyy"}'/>
                    </strong>
                  </p>
                </t>
              </div>
              <div class="col-6">
                <div class="card p-3">
                  <h5>Fournisseur</h5>
                  <p>
                    <strong><t t-esc="reappro.fournisseur_id.name"/></strong><br/>
                    <t t-if="reappro.fournisseur_id.street">
                      <t t-esc="reappro.fournisseur_id.street"/><br/>
                    </t>
                    <t t-if="reappro.fournisseur_id.city">
                      <t t-esc="reappro.fournisseur_id.city"/>
                    </t>
                    <t t-if="reappro.fournisseur_id.phone">
                      <br/>Tél : <t t-esc="reappro.fournisseur_id.phone"/>
                    </t>
                    <t t-if="reappro.fournisseur_id.numero_agrement">
                      <br/>Agrément DPM : <t t-esc="reappro.fournisseur_id.numero_agrement"/>
                    </t>
                  </p>
                </div>
              </div>
            </div>

            <!-- Tableau des médicaments commandés -->
            <table class="table table-bordered table-striped">
              <thead class="table-dark">
                <tr>
                  <th>#</th>
                  <th>Médicament</th>
                  <th>DCI</th>
                  <th>Forme / Dosage</th>
                  <th>Conditionnement</th>
                  <th class="text-center">Qté commandée</th>
                  <th class="text-right">PU (FCFA)</th>
                  <th class="text-right">Total (FCFA)</th>
                </tr>
              </thead>
              <tbody>
                <t t-foreach="reappro.ligne_ids" t-as="ligne">
                  <tr>
                    <td><t t-esc="ligne_index + 1"/></td>
                    <td><t t-esc="ligne.medicament_id.nom_commercial"/></td>
                    <td><t t-esc="ligne.medicament_id.dci or '—'"/></td>
                    <td>
                      <t t-esc="dict(ligne.medicament_id.fields_get(['forme'])['forme']['selection']).get(ligne.medicament_id.forme, '')"/>
                      <t t-if="ligne.medicament_id.dosage"> — <t t-esc="ligne.medicament_id.dosage"/></t>
                    </td>
                    <td><t t-esc="ligne.medicament_id.conditionnement or '—'"/></td>
                    <td class="text-center"><t t-esc="ligne.quantite_commandee"/></td>
                    <td class="text-right"><t t-esc="'%s' % int(ligne.prix_unitaire)"/></td>
                    <td class="text-right"><strong><t t-esc="'%s' % int(ligne.montant_ligne)"/></strong></td>
                  </tr>
                </t>
              </tbody>
              <tfoot>
                <tr class="table-success">
                  <td colspan="7" class="text-right"><strong>MONTANT TOTAL :</strong></td>
                  <td class="text-right"><strong><t t-esc="'%s' % int(reappro.montant_total)"/> FCFA</strong></td>
                </tr>
              </tfoot>
            </table>

            <!-- Conditions et mentions légales -->
            <t t-if="reappro.note_interne">
              <div class="mt-3">
                <strong>Conditions / Notes :</strong>
                <p><t t-esc="reappro.note_interne"/></p>
              </div>
            </t>

            <!-- Signatures -->
            <div class="row mt-5">
              <div class="col-6 text-center">
                <p><strong>Le Pharmacien Responsable</strong></p>
                <br/><br/>
                <p>___________________________</p>
                <p><em>(Signature et cachet)</em></p>
              </div>
              <div class="col-6 text-center">
                <p><strong>Le Fournisseur</strong></p>
                <br/><br/>
                <p>___________________________</p>
                <p><em>(Signature et cachet)</em></p>
              </div>
            </div>

            <!-- Mentions légales -->
            <div class="mt-4 text-muted">
              <small>
                <em>
                  Conformément à la réglementation pharmaceutique en vigueur au Sénégal
                  (Loi n°2013-10 du 28 décembre 2013 — Code de la Santé).
                  Tout médicament doit être accompagné de son autorisation de mise sur le marché (AMM).
                </em>
              </small>
            </div>

          </div>
        </t>
      </t>
    </t>
  </template>
</odoo>
