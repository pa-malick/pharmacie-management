<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Vue formulaire Réapprovisionnement -->
    <record id="view_pharmacie_reappro_form" model="ir.ui.view">
        <field name="name">pharmacie.reappro.form</field>
        <field name="model">pharmacie.reappro</field>
        <field name="arch" type="xml">
            <form string="Bon de commande fournisseur">
                <header>
                    <button name="action_envoyer_commande"
                            string="Envoyer la commande"
                            type="object" class="btn-primary"
                            invisible="statut != 'brouillon'"/>
                    <button name="action_receptionner"
                            string="Réceptionner"
                            type="object" class="btn-success"
                            invisible="statut not in ['commande', 'partiel']"/>
                    <button name="action_annuler"
                            string="Annuler"
                            type="object" class="btn-danger"
                            invisible="statut in ['recu', 'annule']"/>
                    <button name="%(pharmacie_management.action_report_bon_commande)d"
                            string="Imprimer BC" type="action"
                            invisible="statut == 'brouillon'"/>
                    <field name="statut" widget="statusbar"
                           statusbar_visible="brouillon,commande,partiel,recu"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="reference"/>
                        <h1><field name="reference" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Fournisseur">
                            <field name="fournisseur_id"/>
                        </group>
                        <group string="Dates">
                            <field name="date_commande"/>
                            <field name="date_livraison_prevue"/>
                        </group>
                    </group>
                    <!-- Lignes de commande -->
                    <field name="ligne_ids">
                        <list editable="bottom">
                            <field name="medicament_id" options="{'no_create': True}"/>
                            <field name="quantite_commandee"/>
                            <field name="quantite_recue"
                                   column_invisible="parent.statut not in ['commande', 'partiel']"/>
                            <field name="date_peremption_prevue"
                                   column_invisible="parent.statut not in ['commande', 'partiel']"/>
                            <field name="prix_unitaire"/>
                            <field name="montant_ligne" readonly="1"/>
                        </list>
                    </field>
                    <group class="oe_subtotal_footer">
                        <field name="montant_total" readonly="1"
                               class="oe_subtotal_footer_separator"/>
                    </group>
                    <field name="note_interne"
                           placeholder="Conditions de livraison, notes internes..."/>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- Vue liste Réapprovisionnement -->
    <record id="view_pharmacie_reappro_tree" model="ir.ui.view">
        <field name="name">pharmacie.reappro.tree</field>
        <field name="model">pharmacie.reappro</field>
        <field name="arch" type="xml">
            <list string="Bons de commande fournisseur"
                  decoration-success="statut == 'recu'"
                  decoration-warning="statut == 'partiel'"
                  decoration-info="statut == 'commande'"
                  decoration-muted="statut == 'annule'">
                <field name="reference"/>
                <field name="fournisseur_id"/>
                <field name="date_commande"/>
                <field name="date_livraison_prevue"/>
                <field name="montant_total" sum="Total"/>
                <field name="statut"/>
            </list>
        </field>
    </record>

    <!-- Vue recherche Réapprovisionnement -->
    <record id="view_pharmacie_reappro_search" model="ir.ui.view">
        <field name="name">pharmacie.reappro.search</field>
        <field name="model">pharmacie.reappro</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="fournisseur_id"/>
                <separator/>
                <filter name="brouillon" string="Brouillons"
                        domain="[('statut', '=', 'brouillon')]"/>
                <filter name="commande" string="Commandés"
                        domain="[('statut', '=', 'commande')]"/>
                <filter name="partiel" string="Reçus partiellement"
                        domain="[('statut', '=', 'partiel')]"/>
                <filter name="recu" string="Reçus"
                        domain="[('statut', '=', 'recu')]"/>
                <separator/>
                <group expand="1" string="Regrouper par">
                    <filter name="by_fournisseur" string="Fournisseur"
                            context="{'group_by': 'fournisseur_id'}"/>
                    <filter name="by_statut" string="Statut"
                            context="{'group_by': 'statut'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action Réapprovisionnement -->
    <record id="action_pharmacie_reappro" model="ir.actions.act_window">
        <field name="path">pharmacie-reappro</field>
        <field name="name">Réapprovisionnements</field>
        <field name="res_model">pharmacie.reappro</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_pharmacie_reappro_search"/>
    </record>

</odoo>
